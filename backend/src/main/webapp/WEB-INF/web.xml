<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>AI Task Agent Backend</display-name>

    <!-- ═══════════════════════════════════════════════════════════════════
         FILTER ORDER (top = first to execute):
           1. LoggingFilter   — logs every request + response with timing
           2. CorsFilter      — adds CORS headers, handles OPTIONS preflight
           3. ApiPathNormalizationFilter
           4. AuthFilter      — validates JWT on /api/* protected routes
         ═══════════════════════════════════════════════════════════════ -->

    <!-- 1. Logging filter — MUST be first so every request is captured -->
    <filter>
        <filter-name>LoggingFilter</filter-name>
        <filter-class>com.agent.filter.LoggingFilter</filter-class>
        <async-supported>true</async-supported>
    </filter>
    <filter-mapping>
        <filter-name>LoggingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 2. CORS filter must run SECOND (after logging, before auth) -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.agent.filter.CorsFilter</filter-class>
        <async-supported>true</async-supported>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AuthPathAliasFilter</filter-name>
        <filter-class>com.agent.filter.AuthPathAliasFilter</filter-class>
        <async-supported>true</async-supported>
    </filter>
    <filter-mapping>
        <filter-name>AuthPathAliasFilter</filter-name>
        <url-pattern>/auth</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthPathAliasFilter</filter-name>
        <url-pattern>/auth/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>ApiPathNormalizationFilter</filter-name>
        <filter-class>com.agent.filter.ApiPathNormalizationFilter</filter-class>
        <async-supported>true</async-supported>
    </filter>
    <filter-mapping>
        <filter-name>ApiPathNormalizationFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- Auth filter runs second -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.agent.filter.AuthFilter</filter-class>
        <async-supported>true</async-supported>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- ── v1.1 additions ──────────────────────────────────────────────── -->


    <!-- ── v1.2 OAuth token exchange servlets ─────────────────────────── -->

    <servlet>
        <servlet-name>RootRedirectServlet</servlet-name>
        <servlet-class>com.agent.servlet.RootRedirectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RootRedirectServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ApiIndexServlet</servlet-name>
        <servlet-class>com.agent.servlet.ApiIndexServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApiIndexServlet</servlet-name>
        <url-pattern>/api</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ApiIndexServlet</servlet-name>
        <url-pattern>/api/</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AuthIndexServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.AuthIndexServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthIndexServlet</servlet-name>
        <url-pattern>/api/auth</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AuthIndexServlet</servlet-name>
        <url-pattern>/api/auth/</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/auth/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/api/auth/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MeServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.MeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MeServlet</servlet-name>
        <url-pattern>/api/auth/me</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PreferencesServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.PreferencesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PreferencesServlet</servlet-name>
        <url-pattern>/api/auth/preferences</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ThemeServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.ThemeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ThemeServlet</servlet-name>
        <url-pattern>/api/auth/theme</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OAuthLinkServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.OAuthLinkServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OAuthLinkServlet</servlet-name>
        <url-pattern>/api/auth/oauth/link</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OAuthCallbackServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.OAuthCallbackServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OAuthCallbackServlet</servlet-name>
        <url-pattern>/api/auth/oauth/callback</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ZohoOAuthInitServlet</servlet-name>
        <servlet-class>com.agent.servlet.auth.ZohoOAuthInitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ZohoOAuthInitServlet</servlet-name>
        <url-pattern>/api/auth/oauth/zoho/init</url-pattern>
    </servlet-mapping>

    <!-- ── v1.3 File Transfer servlets ────────────────────────────────── -->

    <servlet>
        <servlet-name>UploadSessionServlet</servlet-name>
        <servlet-class>com.agent.servlet.upload.UploadSessionServlet</servlet-class>
        <multipart-config>
            <max-file-size>52428800</max-file-size>
            <max-request-size>262144000</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>UploadSessionServlet</servlet-name>
        <url-pattern>/api/uploads/session/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UploadFileServlet</servlet-name>
        <servlet-class>com.agent.servlet.upload.UploadFileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UploadFileServlet</servlet-name>
        <url-pattern>/api/uploads/file/*</url-pattern>
    </servlet-mapping>

</web-app>
